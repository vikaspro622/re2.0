# Remixer Environment Variables
# Copy this file to .env and fill in your actual API keys

# OpenRouter API Configuration (Primary)
REACT_APP_OPENROUTER_API_KEY=your-openrouter-api-key-here

# OpenAI API Configuration (used for Whisper + legacy fallback)
REACT_APP_OPENAI_API_KEY=your-openai-api-key-here

# Alternative AI APIs (optional)
REACT_APP_ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Database API (for saving remixes)
REACT_APP_DATABASE_API_URL=http://localhost:3001/api

# Twitter API (for direct tweeting)
REACT_APP_TWITTER_API_KEY=your-twitter-api-key-here
REACT_APP_TWITTER_API_SECRET=your-twitter-api-secret-here
REACT_APP_TWITTER_ACCESS_TOKEN=your-twitter-access-token-here
REACT_APP_TWITTER_ACCESS_TOKEN_SECRET=your-twitter-access-token-secret-here 